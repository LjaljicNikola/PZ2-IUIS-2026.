<Window x:Class="NetworkService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:NetworkService.ViewModel"
        xmlns:view="clr-namespace:NetworkService.Views"
        xmlns:notifications="clr-namespace:Notification.Wpf.Controls;assembly=Notification.Wpf"
        xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
        mc:Ignorable="d"
        Title="⚡ DER Network Monitor — Distributed Energy Resources"
        Height="730" Width="1150"
        MinHeight="600" MinWidth="900"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#FF1A1A2E"
        PreviewKeyDown="Window_PreviewKeyDown"
        Focusable="True">

    <!-- CG4: Keyboard shortcuts za navigaciju između prikaza -->
    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Control"
                    Command="{Binding NavCommand}" CommandParameter="NetworkEntities"/>
        <KeyBinding Key="D2" Modifiers="Control"
                    Command="{Binding NavCommand}" CommandParameter="NetworkDisplay"/>
        <KeyBinding Key="D3" Modifiers="Control"
                    Command="{Binding NavCommand}" CommandParameter="MeasurementGraph"/>
        <KeyBinding Key="F4" Modifiers="Alt"
                    Command="{Binding ExitCommand}"/>

        <!-- ✅ UNDO/REDO/UNDO ALL PREČICE -->
        <KeyBinding Key="Z" Modifiers="Control"
                    Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control+Shift"
                    Command="{Binding RedoCommand}"/>
        <KeyBinding Key="U" Modifiers="Control+Shift"
                    Command="{Binding UndoAllCommand}"/>
    </Window.InputBindings>

    <Window.DataContext>
        <viewModel:MainWindowViewModel/>
    </Window.DataContext>

    <!-- DataTemplate → View mapiranje -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModel:NetworkEntitiesViewModel}">
            <view:NetworkEntitiesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:NetworkDisplayViewModel}">
            <view:NetworkDisplayView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:MeasurementGraphViewModel}">
            <view:MeasurementGraphView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <!-- Menu bar -->
                <RowDefinition Height="44"/>
                <!-- Content area -->
                <RowDefinition Height="*"/>
                <!-- Status bar -->
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>

            <!-- ═══ MENU BAR ═══ -->
            <Border Grid.Row="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF0F3460" Offset="0"/>
                        <GradientStop Color="#FF16213E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <DockPanel LastChildFill="False" VerticalAlignment="Center">

                    <!-- Logo / naziv aplikacije -->
                    <TextBlock DockPanel.Dock="Left" Text="⚡ DER Monitor"
                               Foreground="#FF22C55E" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="15,0,30,0"/>

                    <!-- Navigacioni meniji -->
                    <Button DockPanel.Dock="Left"
                            Content="📋 Network Entities  (Ctrl+1)"
                            Command="{Binding NavCommand}" CommandParameter="NetworkEntities"
                            ToolTip="View and manage DER resources — Ctrl+1">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"      Value="Transparent"/>
                                <Setter Property="Foreground"      Value="#FFE2E8F0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize"        Value="13"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="Padding"         Value="14,0"/>
                                <Setter Property="Cursor"          Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#FF22C55E"/>
                                                    <Setter Property="Foreground" Value="#FF0F172A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button DockPanel.Dock="Left"
                            Content="🗺 Network Display  (Ctrl+2)"
                            Command="{Binding NavCommand}" CommandParameter="NetworkDisplay"
                            ToolTip="Drag and drop DER resources on the network grid — Ctrl+2">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"      Value="Transparent"/>
                                <Setter Property="Foreground"      Value="#FFE2E8F0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize"        Value="13"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="Padding"         Value="14,0"/>
                                <Setter Property="Cursor"          Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#FF22C55E"/>
                                                    <Setter Property="Foreground" Value="#FF0F172A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button DockPanel.Dock="Left"
                            Content="📊 Measurement Graph  (Ctrl+3)"
                            Command="{Binding NavCommand}" CommandParameter="MeasurementGraph"
                            ToolTip="View real-time bar charts for DER measurements — Ctrl+3">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"      Value="Transparent"/>
                                <Setter Property="Foreground"      Value="#FFE2E8F0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize"        Value="13"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="Padding"         Value="14,0"/>
                                <Setter Property="Cursor"          Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#FF22C55E"/>
                                                    <Setter Property="Foreground" Value="#FF0F172A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Exit dugme desno -->
                    <Button DockPanel.Dock="Right"
                            Content="✕ Exit  (Alt+F4)"
                            Command="{Binding ExitCommand}"
                            ToolTip="Exit the application — Alt+F4"
                            Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"      Value="#FFDC2626"/>
                                <Setter Property="Foreground"      Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize"        Value="13"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="Padding"         Value="14,0"/>
                                <Setter Property="Cursor"          Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#FFB91C1C"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </DockPanel>
            </Border>

            <!-- ═══ CONTENT AREA ═══ -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"/>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Background="#FF0F3460">
                <DockPanel LastChildFill="False" Margin="10,0">
                    <TextBlock DockPanel.Dock="Left"
                               Text="⚡ DER Network Monitor  |  Valid range: 1 – 5 MW  |  Ctrl+1/2/3 to navigate  |  Ctrl+Z Undo  |  Ctrl+Shift+Z Redo  |  Ctrl+Shift+U Undo All"
                               Foreground="#FF94A3B8" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="CG4 – T4 – G2 – P1"
                               Foreground="#FF22C55E" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

        </Grid>

        <!-- Toast notification overlay -->
        <notifications:NotificationArea
            x:Name="WindowNotificationArea"
            Panel.ZIndex="1000"
            MaxItems="4"
            Position="TopRight"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="10"
            Width="320"
            Height="Auto"/>

    </Grid>
</Window>