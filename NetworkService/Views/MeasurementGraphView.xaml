<UserControl x:Class="NetworkService.Views.MeasurementGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBg"    Color="#FF1A1A2E"/>
        <SolidColorBrush x:Key="SecondaryBg"  Color="#FF16213E"/>
        <SolidColorBrush x:Key="CardBg"       Color="#FF0F3460"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#FF22C55E"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#FFEAB308"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#FFEF4444"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#FFE2E8F0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#FF94A3B8"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#FF334155"/>

        <LinearGradientBrush x:Key="HeaderGrad" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF16A34A" Offset="0"/>
            <GradientStop Color="#FF15803D" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource SecondaryBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FF16213E"/>
                        <Setter Property="Foreground" Value="#FFE2E8F0"/>
                        <Setter Property="Padding"    Value="8,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#FF0F3460"/>
                                <Setter Property="Foreground" Value="#FF22C55E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource CardBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="12,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1E4080"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource BorderColor}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PrimaryBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEVI PANEL ═══ -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBg}" Padding="12">
            <StackPanel>

                <!-- Header -->
                <Border Background="{StaticResource HeaderGrad}" CornerRadius="6"
                        Padding="10" Margin="0,0,0,12">
                    <TextBlock Text="📊 Measurement Graph" FontSize="15" FontWeight="Bold"
                               Foreground="White" TextAlignment="Center"/>
                </Border>

                <!-- Izbor resursa -->
                <Border Background="{StaticResource CardBg}" CornerRadius="6"
                        Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Select DER Resource" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource AccentYellow}" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding AllResources}"
                                  SelectedItem="{Binding SelectedResource, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ComboStyle}"
                                  ToolTip="Choose the resource whose measurement history will be displayed"/>
                    </StackPanel>
                </Border>

                <!-- Undo -->
                <Button Content="↩ Undo Selection" Command="{Binding UndoCommand}"
                        Style="{StaticResource SecondaryBtn}"
                        HorizontalAlignment="Stretch" Margin="0,0,0,12"
                        ToolTip="Revert to the previously selected resource"/>

                <!-- Legenda grafikona -->
                <Border Background="{StaticResource CardBg}" CornerRadius="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Graph Legend" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Rectangle Width="16" Height="16" Fill="#FF22C55E" Margin="0,0,8,0"/>
                            <TextBlock Text="Valid (1 – 5 MW)"
                                       Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Rectangle Width="16" Height="16" Fill="#FFEF4444" Margin="0,0,8,0"/>
                            <TextBlock Text="Invalid (&lt; 1 MW or &gt; 5 MW)"
                                       Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="16" Height="4" Fill="#FFEAB308"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Valid range limits"
                                       Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                        </StackPanel>

                        <TextBlock Text="Graph updates automatically in real time."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- ═══ DESNI PANEL: grafikoni ═══ -->
        <Grid Grid.Column="1" Background="{StaticResource PrimaryBg}">
            <Grid.RowDefinitions>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- G2: Bar grafikon -->
                <RowDefinition Height="*"/>
                <!-- Razdvojnik -->
                <RowDefinition Height="10"/>
                <!-- CG4: Stacked bar po tipovima -->
                <RowDefinition Height="110"/>
                <!-- Margina -->
                <RowDefinition Height="8"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource HeaderGrad}" CornerRadius="6"
                    Padding="10" Margin="10,10,10,0">
                <TextBlock Foreground="White" FontSize="14" FontWeight="Bold">
                    <Run Text="G2 – Bar Chart: last 5 measurements for "/>
                    <Run Text="{Binding SelectedResource.Name, FallbackValue='(no selection)'}"/>
                </TextBlock>
            </Border>

            <!-- G2 Bar grafikon Canvas -->
            <Border Grid.Row="1" Background="{StaticResource CardBg}" CornerRadius="6" Margin="10,8,10,0">
                <Canvas x:Name="GraphCanvas" ClipToBounds="True">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Loaded">
                            <i:InvokeCommandAction Command="{Binding InitializeGraphCommand}"
                                                   CommandParameter="{Binding ElementName=GraphCanvas}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Canvas>
            </Border>

            <!-- CG4: Stacked bar grafikon zastupljenosti tipova -->
            <Border Grid.Row="3" Background="{StaticResource CardBg}" CornerRadius="6" Margin="10,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF0D2A20" CornerRadius="6,6,0,0" Padding="8,5">
                        <TextBlock Text="CG4 – DER Type Distribution (% of total resources)"
                                   Foreground="{StaticResource AccentGreen}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Border>

                    <Canvas Grid.Row="1" x:Name="TypeGraphCanvas" ClipToBounds="True">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Loaded">
                                <i:InvokeCommandAction Command="{Binding InitializeTypeGraphCommand}"
                                                       CommandParameter="{Binding ElementName=TypeGraphCanvas}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Canvas>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
